# Infraestrutura
FLASK_SECRET_KEY=
AUTH_REQUIRED=1
# URL publica do app em producao. Ex.: https://seocontrol.vercel.app
APP_BASE_URL=
# Cache longo para assets estaticos versionados.
SEO_STATIC_CACHE_SECONDS=31536000
SUPABASE_URL=
# Chave publishable usada apenas para login/cadastro via Supabase Auth.
SUPABASE_KEY=
# Obrigatoria no servidor: o backend usa esta chave para ler/gravar dados privados.
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth - configure uma vez no servidor para Search Console + GA4.
# Redirect URI no Google Cloud: https://SEU_DOMINIO/settings/gsc/callback
# APIs no Google Cloud: Search Console API, Google Analytics Data API e Google Analytics Admin API.
# Se APP_BASE_URL estiver preenchida, GOOGLE_OAUTH_REDIRECT_URI pode ficar vazio.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
# Opcional/local: em contas autenticadas a propriedade GA4 e escolhida na tela /settings.
GA4_PROPERTY_ID=

# IA - preencha pelo menos um provedor
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=
# Opcional: ajuste modelos/fallbacks e reduza 429 em lotes grandes.
OPENROUTER_MODEL=openrouter/free
OPENROUTER_FALLBACK_MODELS=openrouter/free
GROQ_MODEL=llama-3.3-70b-versatile
AI_PROVIDER_ORDER=openrouter,groq,gemini,mistral,anthropic,ollama
OPENROUTER_REQUEST_DELAY_SECONDS=3.2
GROQ_REQUEST_DELAY_SECONDS=2.2
GEMINI_REQUEST_DELAY_SECONDS=1.0
# Opcao gratuita local sem API externa. Requer Ollama instalado e modelo baixado.
# Ex.: ollama pull qwen2.5:7b-instruct
OLLAMA_ENABLED=0
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
# Opcional: aumente se uma ferramenta precisar devolver listas grandes em JSON.
AI_MAX_OUTPUT_TOKENS=4000
# Ideias de blog com IA: limite de queries e conteudos existentes enviados no prompt.
BLOG_IDEAS_AI_QUERY_LIMIT=60
BLOG_IDEAS_EXISTING_CONTENT_LIMIT=25

# APIs opcionais
PAGESPEED_API_KEY=

# Shopify SEO automation opcional.
# Use o dominio Admin da loja, normalmente algo.myshopify.com.
SHOPIFY_STORE_DOMAIN=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# Opcional: token Admin API ja gerado. Se vazio, o app usa client_id/client_secret.
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_API_VERSION=2026-04
# Dominio publico usado para montar URLs quando a API nao retornar onlineStoreUrl.
SHOPIFY_PUBLIC_BASE_URL=
# Contexto usado somente nos prompts de SEO da Shopify.
SHOPIFY_SITE_NAME=
SHOPIFY_BUSINESS_CONTEXT=
SHOPIFY_CONTENT_GUIDELINES=

# Crawler on-page opcional.
# Use se algum site bloquear o User-Agent padrao do auditor.
SEO_CRAWLER_USER_AGENT=
SEO_CRAWL_DELAY=1.0
SEO_REQUEST_TIMEOUT=15
SEO_CRAWL_RETRIES=2
# Auditoria on-page: workers paralelos por execucao (1 para modo sequencial).
SEO_ONPAGE_WORKERS=4

# Dados do cliente/site devem ser configurados na tela /settings:
# SITE_URL, GSC_PROPERTY_URL, BUSINESS_CONTEXT, PRIORITY_PAGES, marcas e termos.
